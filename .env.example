# PentaLedger environment configuration
# Copy to .env and fill in values. Never commit .env to version control.

# Neon PostgreSQL connection string (from Neon Console or MCP get_connection_string)
PENTALEDGER_DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Server (optional)
# PENTALEDGER_ADDRESS=0.0.0.0
# PENTALEDGER_PORT=8080
